{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user basic information and association with their billing account.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a purchase or subscription order for hosting services.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "PAID", "FAILED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "planId", "amount", "status", "createdAt"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Represents a support ticket opened by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "REPLIED", "CLOSED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "replies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string", "enum": ["ADMIN", "USER"] },
              "message": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["id", "userId", "email", "subject", "message", "status", "createdAt"]
    "Settings": {
      "title": "Settings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      },
      "required": ["key", "value"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global configuration documents."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile collection."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection, queried by userId for billing area."
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets collection."
    }
  }
}
